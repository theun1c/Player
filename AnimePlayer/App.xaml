<Application x:Class="AnimePlayer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AnimePlayer"
             xmlns:vm="clr-namespace:AnimePlayer.ViewModels"
             xmlns:v="clr-namespace:AnimePlayer.Views.Controls"
             StartupUri="Views\Windows\MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Assets/Themes/MenuButtonTheme.xaml"/>
                <ResourceDictionary Source="Assets/Themes/MenuTextBoxTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type vm:HomeViewModel}">
                <v:HomeView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:PlayerViewModel}">
                <v:PlayerView/>
            </DataTemplate>

        </ResourceDictionary>
    </Application.Resources>
</Application>

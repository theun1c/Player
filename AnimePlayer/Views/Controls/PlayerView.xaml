<UserControl x:Class="AnimePlayer.Views.Controls.PlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AnimePlayer.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="625" 
             d:DesignWidth="1060"
             Background="#121212">
    <Grid>
        <TextBlock Text="Player"
                Foreground="White"
                FontSize="28"
                HorizontalAlignment="Left"
                Margin="80, 20, 0, 20" RenderTransformOrigin="1.376,0.671"/>

        <Grid>
            <!--Разметка контроллера с плеером-->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="625"></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="368"></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>

            <Border Grid.Column="1" 
                    Grid.Row="1" 
                    Background="Black"
                    BorderBrush="AliceBlue"
                    BorderThickness="1">
                <Grid>

                    <!--Внутренняя разметка плеера-->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45*"></RowDefinition>
                        <RowDefinition Height="275*"></RowDefinition>
                        <RowDefinition Height="45*"></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>


                    <!--кнопка (треугольник) -PLAY -->
                    <Polygon Grid.Row="1"
                             Grid.Column="1"
                             Fill="White" 
                             Points="0, 0, 50, 25, 0, 50"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" 
                             >
                        <!--<Polygon.RenderTransform>
                            <ScaleTransform ScaleX="0.5" ScaleY="0.5"/>
                        </Polygon.RenderTransform>-->
                        <Polygon.Effect>
                            <BlurEffect Radius="2"/>
                        </Polygon.Effect>
                    </Polygon>

                    <Slider Value="0" 
                            Minimum="0"
                            Maximum="100" 
                            SelectionStart="0" 
                            IsSelectionRangeEnabled="True" 
                            Grid.Row="2"
                            Grid.Column="2" Margin="37,15,115,10"
                            />

                    
                    <ProgressBar Grid.Row="1"
                                 Grid.ColumnSpan="3"
                                 Height="10"
                                 Width="600"
                                 VerticalAlignment="Bottom"
                                 />
                </Grid>
            </Border>


        </Grid>

    </Grid>
</UserControl>
